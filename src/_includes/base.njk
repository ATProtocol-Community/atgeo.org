<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{% if title %}{{ title }} — ATGeo{% else %}ATGeo — Places for AT Protocol{% endif %}</title>
    {% if page.url == "/" %}<link rel="stylesheet" href="https://unpkg.com/maplibre-gl/dist/maplibre-gl.css" />{% endif %}
    <link rel="icon" type="image/svg+xml" href="/assets/favicon.svg" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="ATGeo" />
    <meta property="og:title" content="{% if title %}{{ title }} — ATGeo{% else %}ATGeo — Places for AT Protocol{% endif %}" />
    <meta property="og:description" content="A Place lexicon for AT Protocol and a lookup service for geographic venues." />
    <meta property="og:image" content="https://atgeo.org/assets/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="{% if title %}{{ title }} — ATGeo{% else %}ATGeo — Places for AT Protocol{% endif %}" />
    <meta name="twitter:description" content="A Place lexicon for AT Protocol and a lookup service for geographic venues." />
    <meta name="twitter:image" content="https://atgeo.org/assets/og-image.png" />
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <div class="page-layout">
      {% set navItems = [
        { url: "/",            label: "Overview" },
        { url: "/usage/",      label: "Usage" },
        { url: "/place/",      label: "Lexicon" },
        { url: "/api/",        label: "XRPC API" },
        { url: "/osm/",        label: "OpenStreetMap" },
        { url: "/overture/",   label: "Overture Maps" },
        { url: "/foursquare/", label: "Foursquare" },
        { url: "/known-gaps/", label: "Roadmap" },
        { url: "/faq/",        label: "FAQ" },
        { url: "/help/",       label: "Help Wanted" }
      ] %}
      <nav class="sidebar" aria-label="Site navigation">
        <div class="sidebar-heading"><a href="/"><img src="/assets/favicon.svg" alt="" class="sidebar-icon" />ATGeo.org</a></div>
        <hr class="sidebar-rule" />
        <button class="nav-toggle" aria-label="Menu" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>
        <ul>
          {% for item in navItems %}
          <li{% if page.url == item.url %} aria-current="page"{% endif %}>
            <a href="{{ item.url }}">{{ item.label }}</a>
          </li>
          {% endfor %}
        </ul>
      </nav>
      <main class="content{% if wide %} content-wide{% endif %}">
        {{ content | safe }}
      </main>
    </div>
    {% if page.url == "/" %}
    <script src="https://unpkg.com/maplibre-gl/dist/maplibre-gl.js"></script>
    <script src="/js/map-demo.js" defer></script>
    <script src="/js/place-display.js" defer></script>
    {% endif %}
    {% if page.url == "/" or page.url == "/api/" %}
    <script src="/js/query-demo.js" defer></script>
    {% endif %}
    <script src="/js/nav-toggle.js" defer></script>
  </body>
</html>
